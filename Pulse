do
    local dragging, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

local sparksLayer = Instance.new("Frame")
sparksLayer.Name = "Sparks"
sparksLayer.Parent = frame
sparksLayer.BackgroundTransparency = 1
sparksLayer.Size = UDim2.new(1, 0, 1, 0)

local function spawnSpark(yOffset, speedSec, sizePx, startDelay)
    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Text = "⚡"
    lbl.Font = Enum.Font.FredokaOne
    lbl.TextScaled = true
    lbl.TextColor3 = COLOR_BLUE
    lbl.Size = UDim2.fromOffset(sizePx, sizePx)
    lbl.Position = UDim2.new(0, -sizePx, 0, yOffset)
    lbl.Parent = sparksLayer
    Instance.new("UICorner", lbl).CornerRadius = UDim.new(1,0)

    task.delay(startDelay or 0, function()
        while lbl.Parent do
            lbl.Position = UDim2.new(0, -sizePx, 0, yOffset)
            local tween = TweenService:Create(lbl, TweenInfo.new(speedSec, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Position = UDim2.new(1, sizePx, 0, yOffset)})
            tween:Play()
            tween.Completed:Wait()
            task.wait(0.3)
        end
    end)
end

spawnSpark(8, 4.5, 14, 0.1)
spawnSpark(24, 5.2, 12, 0.6)
spawnSpark(46, 4.8, 10, 1.0)
spawnSpark(64, 5.5, 8, 1.4)

local isRunning = false
local pulling = false
local speed = 50
local MIN_LEN = 5
local THROW_TO = 50

local function getRope()
    local ropes = workspace:FindFirstChild("Ropes")
    if not ropes then return nil end
    local bucket = ropes:FindFirstChild(player.Name)
    if not bucket then return nil end
    for _, r in ipairs(bucket:GetDescendants()) do
        if r:IsA("RopeConstraint") then
            return r
        end
    end
    return nil
end

local function runCycle()
    local rope = getRope()
    if not rope or isRunning then return end
    isRunning = true
    pulling = false
    easeBtn.Text = "Easing..."

    rope.Length = THROW_TO
    pulling = true
    easeBtn.Text = "Pulling..."
end

easeBtn.MouseButton1Click:Connect(runCycle)
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.X then
        runCycle()
    end
end)

RunService.RenderStepped:Connect(function(dt)
    if pulling then
        local rope = getRope()
        if rope then
            rope.Length = math.max(rope.Length - speed * dt, MIN_LEN)
            if rope.Length <= MIN_LEN then
                pulling = false
                isRunning = false
                easeBtn.Text = "EaseIn: OFF"
            end
        else
            pulling = false
            isRunning = false
            easeBtn.Text = "EaseIn: OFF"
        end
    end
end)
