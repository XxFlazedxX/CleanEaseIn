-- FLZ One-Tap Throw+Pull EaseIn (classic, styled)
-- X / Button: wait 0.2 -> Throw to 50 -> auto Pull to 5
-- Theme: light pink, white, black + animated flowers + draggable + "Made By Flazed"

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer

-- ========= Colors =========
local COLOR_BLACK     = Color3.fromRGB(10, 10, 10)
local COLOR_WHITE     = Color3.fromRGB(255, 255, 255)
local COLOR_LIGHTPINK = Color3.fromRGB(255, 182, 193)

